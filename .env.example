# Razor-Rooster operator dotenv — copy to `.env` and fill in the values
# you have. The bootstrap script auto-loads this file when present;
# values already set in the live environment take precedence.
#
# All credentials are optional in the sense that the bootstrap will run
# whatever's available and cleanly skip the rest. Sources without
# credentials in this list (World Bank, GDELT, USGS, federal_register)
# are no-auth public APIs and always available.

# -- Local store path -----------------------------------------------------
# Where the DuckDB store lives. Defaults to `data/trough.duckdb` under
# the repo root if unset.
# RAZOR_ROOSTER_DB=/path/to/trough.duckdb

# -- Data-ingest credentials (config/ingest_schedule.yaml gates which
#    sources actually get scheduled) ---------------------------------------

# FRED — Federal Reserve Economic Data. Free key: https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=

# ACLED — Armed Conflict Location & Event Data. OAuth2 password grant.
# ACLED_USERNAME=
# ACLED_PASSWORD=

# EIA — U.S. Energy Information Administration. Free key.
# EIA_API_KEY=

# NRC ADAMS — Nuclear Regulatory Commission docket search. Free key.
# NRC_ADAMS_API_KEY=

# regulations.gov — federal rulemaking docket. Free key:
# https://open.gsa.gov/api/regulationsgov/
# REGULATIONS_GOV_API_KEY=

# NOAA CDO — Climate Data Online. Free token:
# https://www.ncdc.noaa.gov/cdo-web/token
# NOAA_CDO_TOKEN=

# -- Polymarket / Kalshi gating ------------------------------------------

# Operator's claimed jurisdiction for the geo gate. The connector blocks
# requests when this resolves to a restricted jurisdiction. Set to your
# actual jurisdiction (the gate is real, not theatre).
# RAZOR_ROOSTER_JURISDICTION=US-NY

# Contact string interpolated into outbound User-Agent headers per
# REQ-PM-COMPAT-002 / REQ-KALSHI-COMPAT-002.
# RAZOR_ROOSTER_CONTACT=ops@example.com

# -- Bootstrap automation toggles -----------------------------------------

# Set to "1" to non-interactively acknowledge each venue's ToS during
# bootstrap (skips the confirmation prompt). The ack is still recorded
# with the live ToS hash; re-prompting still happens if the hash changes
# on a future ToS update.
# RAZORROO_AUTOACK_POLYMARKET=1
# RAZORROO_AUTOACK_KALSHI=1

# Operator-supplied analytical bankroll figure in USD. When set, the
# bootstrap will declare it via `position-engine config --bankroll <usd>`
# the first time it sees a no-bankroll error from `position-engine run`.
# Required to bring the position-engine stage online without manual
# config. The system never tracks real capital; this is for sizing math.
# RAZORROO_BANKROLL_USD=1000

# Set to "1" to hand off to `report watch --on-change` after the bootstrap
# finishes, so the operator gets continuous re-renders of the daily
# report as upstream data arrives.
# RAZORROO_BOOTSTRAP_THEN_WATCH=1

# Watch-loop interval in seconds. Defaults to 3600 (one hour).
# Honored only when RAZORROO_BOOTSTRAP_THEN_WATCH=1.
# RAZORROO_WATCH_INTERVAL=3600
